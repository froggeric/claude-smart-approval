{
  "description": "Auto-approve safe Bash commands using prefix matching and AI evaluation",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}\"/auto-approve.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
